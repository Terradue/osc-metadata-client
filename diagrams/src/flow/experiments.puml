@startuml
title Create the Experiment definition

start

:Start drafting the Experiment ""record.json"" structure;

:Initial Experiment ""record.json"" definition; <<output>>

split
    :OSC Workflow Record link; <<input>>

    :Enrich Experiment Metadata with OSC Properties:
    * ""link.rel"" = ""related"" to the previous Workflow Record;
split again
    :Job Id; <<input>>
    
    :Access to ""/jobs/{jobId}"";
    
    while (status == running)
        :Wait the job execution is over;
    endwhile
    
    if (status == succeeded?) then (yes)
        :Extract the inputs;
          
        :""input.(yaml|json)"" file; <<output>>
        
        :Enrich Experiment Metadata with OSC Properties:
        * ""link.rel"" = ""input"" to the previously created file;

        :Enrich Experiment Metadata with OSC Properties:
        * ""osc:workflow""
        * ""osc-prov:generatedBy"",
        * ""osc-prov:startedAtTime""
        * ""osc-prov:endedAtTime""
        * ""osc-prov:generated""
        * ""osc-prov:describedByWorkflow""
        * ""osc-prov:wasEnactedBy"";
    else (no)
      :Manage exception;
      stop
    endif
end split

:Refined Experiment ""record.json"" definition; <<output>>

:Publish to OSC;

stop

@enduml

