@startuml
title Create the Experiment definition

actor Operator as operator
participant "Open Science Catalog\nClient" as oscc
database "Application Packages Registry" as apr
participant "OGC API Processes" as oap
database "File System" as fs
participant "Open Science Catalog" as osc

operator ++
fs ++
oscc ++

operator -> oscc : Configure Application Package
operator -> oscc : Configure OGC API Records workflow
operator -> oscc : Configure OGC API Processes entry point
operator -> oscc : Configure OGC API Processes Job ID
oscc -> apr ++ : Request CWL Workflow
apr --> oscc -- : Provide the CWL Workflow

oscc -> oscc : Transpile the Application Package\nto OGC API Records

loop StatusInfo.status is "accepted" or "running"
    oscc -> oap ++ : ""GET /jobs/{jobId}""
    oap --> oscc -- : Provide Job StatusInfo
end

alt "succeeded" == StatusInfo.status
    oscc -> oscc : Extract workflow inputs
    oscc -> fs : Serialize ""inputs.yaml""
    oscc -> osc ++ : Upload serialized ""inputs.yaml""
    osc -> oscc -- : ACK
    
    oscc -> oscc : Attach ""inputs.yaml"" link to the\nOGC API Records

    oscc -> fs : Serialize ""experiment.json""
    oscc -> osc ++ : Upload serialized ""experiment.json""
    osc -> oscc -- : ACK
else
    oscc -> oscc : Manage failure
end

@enduml
